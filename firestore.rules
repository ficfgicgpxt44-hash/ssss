rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'ficfgicgpxt44@gmail.com';
    }

    function isValidCase(data) {
      return data.id is string &&
             data.title is string && data.title.size() <= 200 &&
             data.category is string &&
             data.description is string &&
             data.images is list &&
             data.createdAt is number;
    }

    // Cases collection
    match /cases/{caseId} {
      // Allow public list and get for the portfolio
      allow read: if true;
      
      // Only admin can write
      allow create: if isAdmin() && isValidCase(request.resource.data);
      allow update: if isAdmin() && isValidCase(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
