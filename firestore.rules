rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PHASE 3: Primitives ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role-based access
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- PHASE 4: Validation Helpers ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'role']) &&
             data.keys().size() == 4 &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.displayName is string && data.displayName.size() <= 128 &&
             data.role in ['admin', 'viewer'];
    }

    function isValidCase(data) {
      return data.keys().hasAll(['id', 'createdAt', 'title', 'category', 'description', 'images', 'ownerId']) &&
             data.keys().size() == 7 &&
             data.id is string && data.id.size() <= 128 &&
             data.createdAt is number &&
             data.title is string && data.title.size() <= 200 &&
             data.category in ['Endodontics', 'Prosthodontics', 'Surgery', 'Pedodontics', 'Cosmetic Fillings'] &&
             data.description is string && data.description.size() <= 5000 &&
             data.images is list && data.images.size() <= 10 &&
             data.ownerId == request.auth.uid;
    }

    function isValidCV(data) {
      return data.keys().hasAll(['name', 'title', 'summary', 'ownerId']) &&
             data.name is string && data.name.size() <= 128 &&
             data.title is string && data.title.size() <= 128 &&
             data.summary is string && data.summary.size() <= 2000 &&
             data.ownerId == request.auth.uid &&
             (!data.keys().contains('profileImage') || (data.profileImage is string && data.profileImage.size() <= 800000));
    }

    // --- COLLECTIONS ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'viewer';
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().role == existing().role && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email']);
    }

    match /cases/{caseId} {
      allow read: if true;
      allow create: if isEmailVerified() && isValidId(caseId) && isValidCase(incoming());
      allow update: if isEmailVerified() && isOwner(existing().ownerId) && isValidCase(incoming()) &&
                    incoming().ownerId == existing().ownerId &&
                    incoming().createdAt == existing().createdAt;
      allow delete: if isEmailVerified() && isOwner(existing().ownerId);
    }

    match /cv/{userId} {
      allow read: if true;
      allow write: if isEmailVerified() && isOwner(userId) && isValidCV(incoming());
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
    }
  }
}
