rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Allow the specific user email provided in metadata
      return isSignedIn() && (request.auth.token.email == 'ficfgicgpxt44@gmail.com');
    }

    match /cases/{caseId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
