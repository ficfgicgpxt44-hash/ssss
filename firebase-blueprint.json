{
  "entities": {
    "Case": {
      "title": "Clinical Case",
      "description": "A medical/dental clinical case with documentation images",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "createdAt": { "type": "number", "description": "Timestamp in milliseconds" },
        "title": { "type": "string" },
        "category": { 
          "type": "string",
          "enum": ["Endodontics", "Prosthodontics", "Surgery", "Pedodontics", "Cosmetic Fillings"]
        },
        "description": { "type": "string" },
        "images": { 
          "type": "array",
          "items": { "type": "string" },
          "description": "Array of base64 compressed images"
        }
      },
      "required": ["title", "category", "description", "images"]
    }
  },
  "firestore": {
    "cases/{caseId}": {
      "schema": "Case",
      "description": "Collection of clinical cases"
    }
  }
}
