{
  "entities": {
    "Case": {
      "title": "Clinical Case",
      "description": "Details about a dental clinical case",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier (UUID)" },
        "title": { "type": "string", "description": "Title of the case" },
        "category": { "type": "string", "description": "Medical category" },
        "description": { "type": "string", "description": "Detailed description" },
        "images": { "type": "array", "items": { "type": "string" }, "description": "List of base64 image strings" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" }
      },
      "required": ["id", "title", "category", "images", "createdAt"]
    }
  },
  "firestore": {
    "cases": {
      "schema": "Case",
      "description": "Public collection of dental portfolio cases"
    }
  }
}
