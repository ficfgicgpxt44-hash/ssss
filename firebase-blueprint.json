{
  "entities": {
    "Case": {
      "title": "Clinical Case",
      "description": "A dental clinical case showcased in the portfolio.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "createdAt": { "type": "number" },
        "title": { "type": "string" },
        "category": { 
          "type": "string",
          "enum": ["Endodontics", "Prosthodontics", "Surgery", "Pedodontics", "Cosmetic Fillings"]
        },
        "description": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "createdAt", "title", "category", "description", "images"]
    }
  },
  "firestore": {
    "cases": {
      "schema": "Case",
      "description": "Collection of clinical cases."
    }
  }
}
